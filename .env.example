# This file contains the environment variables for the transit-schedule application.
# Copy this file to .env and replace the values with your own.

# The transit agency you want to use (RTL, STM, or STL). Defaults to RTL.
TRANSIT=RTL

# The bus stop code for which you want to retrieve the schedule (Single stop fallback).
STOP_CODE=12345

# Advanced: Multiple stops configuration in JSON format.
# If set, this overrides STOP_CODE, TARGET_ROUTE, and TARGET_DIRECTION.
# Example: STOPS_CONFIG='[{"stop_code": "31592", "route_id": "14", "direction": "Longueuil"}, {"stop_code": "32752", "route_id": "44", "direction": "Panama"}]'
STOPS_CONFIG=

# The hostname or IP address of your MQTT broker.
MQTT_HOST=your_mqtt_broker_host

# The port of your MQTT broker. Defaults to 1883 if not specified.
MQTT_PORT=1883

# The username for your MQTT broker. Leave empty if not required.
MQTT_USERNAME=

# The password for your MQTT broker. Leave empty if not required.
MQTT_PASSWORD=

# Set to "true" to enable TLS for the MQTT connection.
MQTT_USE_TLS=false

# Set to "true" to enable Home Assistant MQTT discovery.
HASS_DISCOVERY_ENABLED=true

# The Home Assistant discovery prefix. Defaults to "homeassistant".
HASS_DISCOVERY_PREFIX=homeassistant

# Filter for a specific bus direction/headsign (Single stop fallback).
TARGET_DIRECTION=Direction Terminus Panama

# Filter for a specific bus route ID (Single stop fallback).
TARGET_ROUTE=

# Data source strategy ("live" or "gtfs")
RETRIEVAL_METHOD=live

# Output language ("en" or "fr")
LANGUAGE=fr

# Timezone for the application
TZ=America/Montreal
